{
  "routes": [
    {
      "src": "/admin/config.yml",
      "dest": "/admin/config.yml",
      "headers": { "content-type": "text/yaml; charset=utf-8" }
    },
    {
      "src": "/admin(/?)",
      "dest": "/admin/index.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/_astro/(.*)$",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "^/_server-islands/([^/]+?)/?$",
      "dest": "_render"
    },
    {
      "src": "^/_image/?$",
      "dest": "_render"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "_render"
    },
    {
      "src": "^/.*$",
      "dest": "_render"
    }
  ]
}
