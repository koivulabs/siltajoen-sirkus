---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import siiloDataRaw from "../data/siilo.json";
import { getAsset } from "../utils/assets";
const siiloData = siiloDataRaw as any;

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/kuvia/*.{jpeg,jpg,png,gif,JPG}');
const getImg = (path: string) => getAsset(path, images);
---

<BaseLayout 
  title="Siilo" 
  description="Tutustu Siltajoen Sirkuksen moderniin siiloon ja ensiluokkaiseen rehulogistiikkaan. Puhtaus, laatu ja automatisoitu viljan varastointi ovat toimintamme keskiössä."
>
  <!-- Hero Section -->
  <section class="px-8 py-20 bg-surface">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div class="reveal">
        <span class="inline-block px-4 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase mb-6">
            {siiloData.heroTagline}
        </span>
        <h1 class="text-4xl sm:text-5xl md:text-8xl font-black leading-[0.9] tracking-tighter mb-8">
            {siiloData.heroTitle.split('.').map((part: string, i: number) => i === 0 ? part : <span class="text-primary italic">.{part}</span>)}
        </h1>
        <p class="text-xl text-on-background/70 max-w-lg mb-10 leading-relaxed">
            {siiloData.heroBody}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#tuotteet" class="bg-primary text-on-primary px-10 py-4 rounded-full font-bold uppercase text-xs tracking-widest hover:brightness-110 transition-all inline-block">
              Verkkokaupan suosikit
          </a>
        </div>
      </div>
      <div class="relative reveal">
        <div class="aspect-[4/5] rounded-3xl bg-neutral-200 overflow-hidden shadow-2xl flex items-center justify-center text-neutral-400 relative">
          {getAsset(siiloData.heroImage) ? (
            <Image 
              src={getAsset(siiloData.heroImage)!} 
              alt="Maatilan rehupussit ja kanat" 
              class="absolute inset-0 w-full h-full object-cover" 
              style={`object-position: ${siiloData.heroFocalX ?? 50}% ${siiloData.heroFocalY ?? 50}%`}
              width={800}
              height={1000}
              loading="eager"
            />
          ) : (
            <img loading="lazy" src={siiloData.heroImage} alt="Maatilan rehupussit ja kanat" class="absolute inset-0 w-full h-full object-cover" style={`object-position: ${siiloData.heroFocalX ?? 50}% ${siiloData.heroFocalY ?? 50}%`} onerror="this.style.display='none'" />
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Products Section -->
  {siiloData.products && (
    <section id="tuotteet" class="px-8 py-24 bg-surface-container/30">
      <div class="max-w-7xl mx-auto">
        <div class="mb-16 reveal">
           <span class="text-primary font-bold uppercase tracking-[0.2em] text-xs mb-4 block">Parhaat eväät</span>
           <h2 class="text-4xl md:text-6xl font-black italic uppercase tracking-tighter">Suosituimmat tuotteet</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
          {siiloData.products.map((item: any) => (
            <div class="bg-white rounded-[2.5rem] overflow-hidden border border-outline/5 shadow-lg group reveal">
              <div class="aspect-square bg-neutral-100 relative overflow-hidden">
                {getImg(item.image) ? (
              <Image 
                src={getImg(item.image)!} 
                alt={item.title} 
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
                width={600}
                height={600}
              />
            ) : (
                <img src={item.image} alt={item.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            )}
                <div class="absolute top-6 right-6 bg-white px-4 py-2 rounded-full font-black text-sm italic shadow-md">
                   {item.price}
                </div>
              </div>
              <div class="p-8 space-y-4">
                <h3 class="text-2xl font-black uppercase italic tracking-tight">{item.title}</h3>
                <p class="text-on-surface/50 text-sm leading-relaxed">{item.description}</p>
                <a href={item.url} target="_blank" class="flex items-center gap-2 font-bold uppercase tracking-widest text-xs text-primary group-hover:gap-4 transition-all">
                   Tilaa verkkokaupasta <span class="material-symbols-outlined text-sm">shopping_basket</span>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Content Section -->
  <section class="px-8 py-24">
    <div class="max-w-4xl mx-auto text-center mb-20 reveal">
      <h2 class="text-3xl md:text-5xl font-black mb-8 tracking-tighter">Silo &amp; Logistiikka</h2>
      <p class="text-xl leading-relaxed text-on-background/80">
          Tutustu Siltajoen Sirkuksen moderniin siiloon ja ensiluokkaiseen rehulogistiikkaan. Puhtaus, laatu ja automatisoitu viljan varastointi ovat toimintamme keskiössä.
      </p>
    </div>
    <div class="max-w-7xl mx-auto grid md:grid-cols-3 gap-8">
      {siiloData.featureCards.map((card: any, i: number) => (
        <div class="p-10 border border-outline rounded-3xl hover:border-primary/30 transition-colors bg-white reveal" style={`transition-delay: ${i * 100}ms`}>
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-8">
            <span class="material-symbols-outlined text-3xl">{card.icon}</span>
          </div>
          <h3 class="text-2xl font-black mb-4">{card.title}</h3>
          <p class="text-on-background/70 leading-relaxed">
              {card.body}
          </p>
        </div>
      ))}
    </div>
  </section>

  <!-- Testimonials Section -->
  {siiloData.testimonials && (
    <section class="px-8 py-24 bg-surface-container/50 border-t border-outline/5">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl md:text-5xl font-black mb-16 tracking-tighter text-center reveal">Mitä asiakkaamme sanovat</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {siiloData.testimonials.map((t: any, i: number) => (
            <div class="bg-white p-10 rounded-[3rem] border border-outline/10 shadow-lg reveal" style={`transition-delay: ${i * 200}ms`}>
              <div class="flex gap-2 text-primary mb-6">
                {[...Array(5)].map(() => <span class="material-symbols-outlined fill-1">star</span>)}
              </div>
              <p class="text-xl italic mb-8 leading-relaxed">"{t.text}"</p>
              <div class="flex items-center justify-between mt-auto">
                <span class="font-bold uppercase tracking-widest text-xs">{t.name}</span>
                <span class="text-on-surface/40 text-xs">{t.date}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Stats Banner -->
  <section class="bg-[#1A1A1A] text-white py-20 px-8">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12 text-center text-sm reveal">
      {siiloData.stats.map((stat: any) => (
        <div class="flex flex-col items-center justify-center p-4">
          <p class="text-primary text-3xl font-black mb-2">{stat.value}</p>
          <div class="uppercase tracking-[0.2em] font-bold opacity-60">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="px-8 py-24">
    <div class="max-w-5xl mx-auto rounded-[3rem] bg-primary text-on-primary p-12 md:p-20 text-center reveal">
      <h2 class="text-3xl md:text-6xl font-black mb-8 tracking-tighter">Haluatko tietää lisää?</h2>
      <p class="text-[white]/80 text-lg mb-12 max-w-xl mx-auto">Vastaamme mielellämme kysymyksiisi eläintemme ravinnosta ja sirkuksemme toiminnasta.</p>
      <form id="siiloContactForm" class="flex flex-col md:flex-row gap-4 max-w-md mx-auto">
        <input class="flex-grow rounded-full border-none px-8 py-4 text-[#1A1A1A] placeholder:text-[#1A1A1A]/50 focus:ring-2 focus:ring-[white]" name="email" placeholder="Sähköpostiosoitteesi" required type="email"/>
        <button id="siiloSubmitBtn" class="bg-white text-primary px-10 py-4 rounded-full font-bold uppercase text-xs tracking-widest hover:brightness-110 transition-all flex items-center justify-center gap-2" type="submit">
            Lähetä
        </button>
      </form>
      <p id="siiloFormStatus" class="mt-6 font-bold text-sm hidden"></p>
    </div>
  </section>

  <script>
    const siiloForm = document.getElementById('siiloContactForm') as HTMLFormElement;
    const siiloStatus = document.getElementById('siiloFormStatus');
    const siiloBtn = document.getElementById('siiloSubmitBtn') as HTMLButtonElement;

    if (siiloForm) {
      siiloForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (siiloStatus) {
            siiloStatus.classList.remove('hidden');
            siiloStatus.innerText = 'Lähetetään...';
        }
        siiloBtn.disabled = true;

        try {
          const formData = new FormData(siiloForm);
          formData.append('type', 'contact');
          formData.append('name', 'Siilo-sivun kysyjä');
          formData.append('message', 'Haluan lisätietoja siilon toiminnasta.'); // Default message
          
          const response = await fetch('/api/contact', {
            method: 'POST',
            body: formData,
          });
          const result = await response.json();
          
          if (result.success) {
            if (siiloStatus) {
                siiloStatus.innerText = result.message;
                siiloStatus.className = 'mt-6 text-sm font-bold text-white';
            }
            siiloForm.reset();
          } else {
            throw new Error(result.message);
          }
        } catch (err: any) {
          if (siiloStatus) {
              siiloStatus.innerText = err.message || 'Hups, jotain meni pieleen.';
              siiloStatus.className = 'mt-6 text-sm font-bold text-[white]/80';
          }
        } finally {
          siiloBtn.disabled = false;
        }
      });
    }
  </script>
</BaseLayout>
