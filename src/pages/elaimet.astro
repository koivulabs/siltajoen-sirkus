---
import BaseLayout from "../layouts/BaseLayout.astro";
import animalsDataRaw from "../data/animals.json";
const animalsData = animalsDataRaw as any;
---

<BaseLayout 
  title="Eläimet" 
  description="Tutustu Siltajoen Sirkuksen eläinasukkaisiin. Meiltä löydät erirotuiset kanat, viiriäiset, ankat ja monet muut siivekkäät ystävät."
>
  <div class="px-6 max-w-7xl mx-auto pt-16">
    <!-- Hero Section -->
    <header class="mb-24 mt-10 reveal">
      <span class="text-primary font-bold uppercase tracking-[0.3em] text-xs mb-4 block">Sirkuksen tähdet</span>
      <h1 class="font-headline text-5xl sm:text-6xl md:text-8xl font-black text-on-surface leading-tight mb-8 tracking-tighter italic uppercase">{animalsData.hero.title}</h1>
      <div class="aspect-[16/9] w-full bg-neutral-100 rounded-[3rem] overflow-hidden shadow-2xl relative border-8 border-white">
        <img 
          src={animalsData.hero.image} 
          alt="Siltajoen Sirkuksen eläimet" 
          class="w-full h-full object-cover"
          style={`object-position: ${animalsData.hero.focalX ?? 50}% ${animalsData.hero.focalY ?? 50}%`}
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
      </div>
    </header>

    <!-- Navigation Shortcuts -->
    <nav class="flex flex-wrap gap-4 mb-24 reveal">
      {animalsData.chickenBreeds.map((breed: any) => (
        <a href={`#${breed.name.toLowerCase().replace(/\s/g, '-')}`} class="px-6 py-3 bg-surface-container rounded-full text-sm font-bold hover:bg-primary hover:text-on-primary transition-all uppercase tracking-wider">
          {breed.name}
        </a>
      ))}
    </nav>

    <!-- Special Categories -->
    {animalsData.specialCategories.map((cat: any, i: number) => (
      <section class="mb-32 reveal">
        <div class={`flex flex-col ${i % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-20 items-center`}>
          <div class="lg:w-1/2 space-y-8">
            <h2 class="font-headline text-4xl md:text-6xl font-black italic tracking-tight uppercase leading-[0.9]">{cat.subtitle}</h2>
            <div class="space-y-6 text-xl text-on-surface-variant leading-relaxed">
              {cat.description.map((p: string) => <p>{p}</p>)}
            </div>
            <a href="/yhteystiedot" class="inline-block px-10 py-4 bg-primary text-on-primary rounded-full font-bold uppercase text-sm tracking-widest hover:brightness-110 transition-all shadow-xl">
              Kysy lisää tästä rodusta
            </a>
          </div>
          <div class="lg:w-1/2 relative">
            <div class="aspect-square bg-zinc-100 rounded-[4rem] overflow-hidden shadow-2xl border-4 border-white rotate-2">
              <img src={cat.image} alt={cat.subtitle} class="w-full h-full object-cover" style={`object-position: ${cat.focalX ?? 50}% ${cat.focalY ?? 50}%`} />
            </div>
          </div>
        </div>
      </section>
    ))}

    <!-- Breeds Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-32">
      {animalsData.chickenBreeds.map((breed: any) => (
        <section id={breed.name.toLowerCase().replace(/\s/g, '-')} class="bg-surface-container rounded-[3rem] p-10 md:p-14 space-y-10 group hover:shadow-2xl transition-all duration-500 border border-outline/5 reveal">
          <div class="aspect-[4/3] rounded-[2.5rem] overflow-hidden shadow-xl border-4 border-white flex items-center justify-center text-neutral-400 relative">
            {breed.image ? (
              <img 
                src={breed.image} 
                alt={breed.name} 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" 
                style={`object-position: ${breed.focalX ?? 50}% ${breed.focalY ?? 50}%`}
                loading="lazy"
              />
            ) : (
              <span class="material-symbols-outlined text-6xl opacity-20">pest_control_rodent</span>
            )}
          </div>
          <div class="space-y-6">
            <h3 class="font-headline text-4xl md:text-5xl font-black italic tracking-tighter uppercase leading-none">{breed.name}</h3>
            <div class="space-y-4 text-on-surface-variant leading-relaxed">
               {breed.description.map((p: string) => <p>{p}</p>)}
            </div>
            
            <div class="pt-6 border-t border-outline/10 flex flex-wrap gap-8 items-end justify-between">
              <div class="space-y-4">
                {breed.prices.map((price: any) => (
                  <div class="flex items-center gap-4">
                    <span class="text-xs font-bold uppercase tracking-widest text-primary/60">{price.label}</span>
                    <span class="text-2xl font-black italic">{price.amount}</span>
                  </div>
                ))}
              </div>
              <a href={`/yhteystiedot?aihe=${encodeURIComponent(breed.name)}`} class="px-8 py-4 bg-zinc-900 text-white rounded-full font-bold uppercase text-xs tracking-widest hover:bg-primary transition-all shadow-lg">
                Kysy saatavuutta
              </a>
            </div>
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
