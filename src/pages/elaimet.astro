---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout 
  title="Eläimet" 
  description="Löydä käsyksi kasvatetut rotukanat ja untuvikot Siltajoen Sirkuksesta. Marans, Silkkikanat, Araucana ja Orpington. Toimimme Leppävedellä ja Vaajakoskella."
>
  <!-- Hero Section -->
  <section class="relative px-6 py-20 lg:py-32 overflow-hidden">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div class="z-10">
        <span class="inline-block text-secondary font-bold tracking-[0.2em] uppercase text-sm mb-6">Siltajoen Sirkus Presents</span>
        <h1 class="font-headline text-6xl lg:text-8xl font-black text-on-surface leading-[0.9] mb-10 uppercase italic">
            Sylissä <br/> <span class="text-primary">Kasvaneita</span>
        </h1>
        <p class="text-xl lg:text-2xl text-on-surface-variant leading-relaxed max-w-xl font-medium">
            Kaikki eläimemme on kasvatettu rakkaudella ja huolenpidolla. Ne ovat tottuneet ihmisen läheisyyteen, ääniin ja sirkuselämän vilinään. Jokainen siivekäs on meillä perheenjäsen – sylissä pidetty ja onnellisena varttunut.
        </p>
      </div>
      <div class="relative">
        <div class="aspect-[4/5] rounded-xl overflow-hidden shadow-2xl transform rotate-2">
          <div class="w-full h-full bg-surface-container-highest flex items-center justify-center text-on-surface-variant text-center p-12 italic border-2 border-dashed border-outline-variant">
              Asiakkaan valitsema kuva: [Pääkuva: sylissä pidetty untuvikko]
              <img src="/placeholder-main.jpg" alt="Untuvikko" class="absolute inset-0 w-full h-full object-cover" onerror="this.style.display='none'" />
          </div>
        </div>
        <div class="absolute -bottom-10 -left-10 w-64 h-64 bg-primary-container/20 rounded-full blur-3xl -z-10"></div>
      </div>
    </div>
  </section>

  <!-- Product Grid Section -->
  <section class="bg-surface-container-low py-32 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-20 gap-8">
        <div>
          <h2 class="font-headline text-5xl font-black text-on-surface mb-4 uppercase italic">Sulkapeitteiset Tähdet</h2>
          <p class="text-on-surface-variant text-lg max-w-md">Löydä uusi perheenjäsen sirkuksen laadukkaimmista ja rakastetuimmista roduista.</p>
        </div>
        <div class="flex flex-wrap gap-3">
          <span class="bg-tertiary-container text-on-tertiary-container px-6 py-2 rounded-full text-xs font-black uppercase flex items-center gap-2">
            <span class="material-symbols-outlined text-base">potted_plant</span>
            Käsin kasvatettu
          </span>
          <span class="bg-secondary-container text-on-secondary-container px-6 py-2 rounded-full text-xs font-black uppercase flex items-center gap-2">
            <span class="material-symbols-outlined text-base">verified</span>
            Terveystarkastettu
          </span>
        </div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10">
        <!-- Marans -->
        <article class="group">
          <div class="aspect-square rounded-xl overflow-hidden mb-8 bg-surface-container border border-outline-variant/30 flex items-center justify-center text-center p-6 text-sm italic text-on-surface-variant transition-transform duration-500 group-hover:scale-105 relative">
              Asiakkaan valitsema kuva: [Marans]
              <img src="/placeholder-marans.jpg" alt="Marans" class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:opacity-100 transition-opacity" onerror="this.style.display='none'" />
          </div>
          <h3 class="font-headline text-3xl font-black mb-2 uppercase italic">Marans</h3>
          <p class="text-on-surface-variant mb-6 text-lg">Ranskan ylpeys, suklaanruskeat munat.</p>
          <div class="flex items-center justify-between">
            <span class="text-primary font-black text-2xl">45€/kpl</span>
            <a class="flex items-center gap-2 text-secondary font-bold uppercase text-sm tracking-widest hover:gap-4 transition-all" href="/yhteystiedot">
                Varaa
                <span class="material-symbols-outlined">arrow_forward</span>
            </a>
          </div>
        </article>

        <!-- Silkkikanat -->
        <article class="group">
          <div class="aspect-square rounded-xl overflow-hidden mb-8 bg-surface-container border border-outline-variant/30 flex items-center justify-center text-center p-6 text-sm italic text-on-surface-variant transition-transform duration-500 group-hover:scale-105 relative">
              Asiakkaan valitsema kuva: [Silkkikanat]
              <img src="/placeholder-silkkikanat.jpg" alt="Silkkikanat" class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:opacity-100 transition-opacity" onerror="this.style.display='none'" />
          </div>
          <h3 class="font-headline text-3xl font-black mb-2 uppercase italic">Silkkikanat</h3>
          <p class="text-on-surface-variant mb-6 text-lg">Maailman pehmeimmät lemmikit.</p>
          <div class="flex items-center justify-between">
            <span class="text-primary font-black text-2xl">35€/kpl</span>
            <a class="flex items-center gap-2 text-secondary font-bold uppercase text-sm tracking-widest hover:gap-4 transition-all" href="/yhteystiedot">
                Varaa
                <span class="material-symbols-outlined">arrow_forward</span>
            </a>
          </div>
        </article>

        <!-- Araucana -->
        <article class="group">
          <div class="aspect-square rounded-xl overflow-hidden mb-8 bg-surface-container border border-outline-variant/30 flex items-center justify-center text-center p-6 text-sm italic text-on-surface-variant transition-transform duration-500 group-hover:scale-105 relative">
              Asiakkaan valitsema kuva: [Araucana]
              <img src="/placeholder-araucana.jpg" alt="Araucana" class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:opacity-100 transition-opacity" onerror="this.style.display='none'" />
          </div>
          <h3 class="font-headline text-3xl font-black mb-2 uppercase italic">Araucana</h3>
          <p class="text-on-surface-variant mb-6 text-lg">Turkoosien munien mestari.</p>
          <div class="flex items-center justify-between">
            <span class="text-primary font-black text-2xl">40€/kpl</span>
            <a class="flex items-center gap-2 text-secondary font-bold uppercase text-sm tracking-widest hover:gap-4 transition-all" href="/yhteystiedot">
                Varaa
                <span class="material-symbols-outlined">arrow_forward</span>
            </a>
          </div>
        </article>

        <!-- Orpington -->
        <article class="group">
          <div class="aspect-square rounded-xl overflow-hidden mb-8 bg-surface-container border border-outline-variant/30 flex items-center justify-center text-center p-6 text-sm italic text-on-surface-variant transition-transform duration-500 group-hover:scale-105 relative">
              Asiakkaan valitsema kuva: [Orpington]
              <img src="/placeholder-orpington.jpg" alt="Orpington" class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:opacity-100 transition-opacity" onerror="this.style.display='none'" />
          </div>
          <h3 class="font-headline text-3xl font-black mb-2 uppercase italic">Orpington</h3>
          <p class="text-on-surface-variant mb-6 text-lg">Lempeä jättiläinen.</p>
          <div class="flex items-center justify-between">
            <span class="text-primary font-black text-2xl">50€/kpl</span>
            <a class="flex items-center gap-2 text-secondary font-bold uppercase text-sm tracking-widest hover:gap-4 transition-all" href="/yhteystiedot">
                Varaa
                <span class="material-symbols-outlined">arrow_forward</span>
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Why Section -->
  <section class="py-32 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="bg-surface-container-highest rounded-xl p-12 lg:p-24 relative overflow-hidden">
        <div class="max-w-2xl relative z-10">
          <h2 class="font-headline text-5xl lg:text-6xl font-black text-on-surface mb-10 leading-tight uppercase italic">
              Miksi valita <br/><span class="text-primary">Siltajoen siivekäs?</span>
          </h2>
          <div class="space-y-8 text-xl text-on-surface-variant">
            <p class="font-medium">
                Meillä uskotaan, että onnellinen kana on paras lemmikki ja munija. Jokainen untuvikko aloittaa elämänsä ihmisen sylissä, mikä tekee linnuistamme poikkeuksellisen kesyjä ja luottavaisia.
            </p>
            <div class="grid sm:grid-cols-2 gap-8">
              <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-primary font-bold text-3xl">favorite</span>
                <div>
                  <h4 class="font-black uppercase italic text-sm mb-1">Käsin kesytetty</h4>
                  <p class="text-base">Linnut eivät pelkää käsittelyä.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-primary font-bold text-3xl">music_note</span>
                <div>
                  <h4 class="font-black uppercase italic text-sm mb-1">Sirkuskoulutettu</h4>
                  <p class="text-base">Tottuneet meteliin ja lapsiin.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-primary font-bold text-3xl">egg</span>
                <div>
                  <h4 class="font-black uppercase italic text-sm mb-1">Vastuullinen</h4>
                  <p class="text-base">Valitsemme vain parhaat emolinjat.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-primary font-bold text-3xl">home</span>
                <div>
                  <h4 class="font-black uppercase italic text-sm mb-1">Kotimainen</h4>
                  <p class="text-base">Kasvatettu Keski-Suomessa.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="absolute right-0 top-0 h-full w-1/3 bg-gradient-to-l from-primary/10 to-transparent hidden lg:block"></div>
        <div class="absolute -right-32 -bottom-32 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-32 px-6 bg-surface-container-low">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-headline text-5xl font-black text-on-surface mb-16 text-center uppercase italic">Usein kysytyt kysymykset kanoista</h2>
      <div class="space-y-12">
        <article class="bg-surface p-10 rounded-xl editorial-shadow border-l-8 border-primary">
          <h3 class="font-headline text-2xl font-black mb-4 uppercase italic">Miten varaan untuvikkoja tai kanoja?</h3>
          <p class="text-on-surface-variant text-lg">Laita meille viestiä yhteystietolomakkeen kautta tai soita suoraan. Sovimme tapaamisen sirkukselle Leppävedelle tai Vaajakoskelle, jossa voit tutustua lintuihin ennen ostopäätöstä.</p>
        </article>
        <article class="bg-surface p-10 rounded-xl editorial-shadow border-l-8 border-primary">
          <h3 class="font-headline text-2xl font-black mb-4 uppercase italic">Mitä tarvitsen kanojen hoitoon?</h3>
          <p class="text-on-surface-variant text-lg">Tarvitset suojaisan kanalan, turvallisen ulkoilualueen, laadukasta rehua ja raikasta vettä. Ohjeistamme mielellämme kaikissa hoitoon liittyvissä asioissa kaupanteon yhteydessä.</p>
        </article>
        <article class="bg-surface p-10 rounded-xl editorial-shadow border-l-8 border-primary">
          <h3 class="font-headline text-2xl font-black mb-4 uppercase italic">Ovatko kaikki rodut kilttejä lapsille?</h3>
          <p class="text-on-surface-variant text-lg">Valitsemme jalostukseen vain hyväluonteisia yksilöitä. Erityisesti Silkkikanat ja Orpingtonit tunnetaan erittäin lempeästä luonteestaan ja soveltuvat mainiosti lapsiperheisiin.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-32 px-6" id="yhteys">
    <div class="max-w-4xl mx-auto text-center">
      <span class="text-primary font-black tracking-widest uppercase text-sm mb-6 block">Haluatko varata omasi?</span>
      <h2 class="font-headline text-7xl font-black mb-10 uppercase italic">Ota Yhteyttä</h2>
      <p class="text-2xl text-on-surface-variant mb-16 leading-relaxed font-medium">
          Hinnat alk. 35€/kpl. Linnut myydään vain hyviin ja vastuullisiin koteihin. <br/>Laita viestiä ja sovitaan vierailu sirkuksen tiluksille!
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-6">
        <a href="/yhteystiedot" class="bg-primary text-on-primary px-12 py-5 rounded-full font-black text-lg uppercase tracking-wider hover:scale-105 transition-transform shadow-xl shadow-primary/30 inline-block">
            Lähetä Viesti
        </a>
        <a href="tel:+358401234567" class="bg-secondary-container text-on-secondary-container px-12 py-5 rounded-full font-black text-lg uppercase tracking-wider hover:scale-105 transition-transform inline-block">
            Soita Meille
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
