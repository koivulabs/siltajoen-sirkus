---
import BaseLayout from "../layouts/BaseLayout.astro";
import contactDataRaw from "../data/contact.json";
const c = contactDataRaw as any;
const phoneLink = c.phone.replace(/\s/g,'').replace('+358','0');

// Rakenna Google Maps -iframen URL contact.jsonin osoitteesta. Käytämme
// `https://www.google.com/maps?q=...&output=embed` -muotoa, joka ei vaadi
// API-avainta ja päivittyy automaattisesti aina kun osoite muuttuu adminissa.
const mapQuery = encodeURIComponent(`${c.street} ${c.city}`);
const mapEmbedUrl = `https://www.google.com/maps?q=${mapQuery}&output=embed`;
const mapDirUrl = `https://www.google.com/maps/dir/?api=1&destination=${mapQuery}`;
---

<BaseLayout
  title="Yhteystiedot"
  description="Ota yhteyttä Siltajoen Sirkukseen. Löydät meidät Siltajoelta Leppävedeltä. Kysy eläimistä, rehuista tai ota yhteyttä."
>
  <div class="px-6 max-w-7xl mx-auto pt-16">
    <!-- Hero Section -->
    <header class="mb-24 mt-10 reveal">
      <span class="text-primary font-bold uppercase tracking-[0.3em] text-xs mb-4 block">{c.page.heroTagline}</span>
      <h1 class="font-headline text-4xl sm:text-6xl md:text-8xl font-black text-on-surface leading-tight mb-8 tracking-tighter italic">{c.page.heroTitle}</h1>
      <p class="text-on-surface-variant text-xl md:text-2xl max-w-3xl leading-relaxed font-light">
          {c.page.heroBody}
      </p>
    </header>

    <!-- Contact Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start mb-24">
      <!-- Information Side -->
      <aside class="space-y-12 reveal">
        <div class="bg-surface-container-low rounded-[2.5rem] p-12 space-y-12 border border-outline/5">
          <section>
            <h2 class="font-headline text-3xl font-black mb-8 italic tracking-tight">Yhteystiedot</h2>
            <div class="space-y-8">
              <div class="flex items-start gap-6">
                <div class="bg-primary/10 text-primary p-4 rounded-full">
                  <span class="material-symbols-outlined text-2xl" data-icon="location_on">location_on</span>
                </div>
                <div>
                  <p class="font-bold text-lg mb-1">Päämaja</p>
                  <address class="text-on-surface-variant not-italic leading-relaxed">{c.street},<br/>{c.city}</address>
                </div>
              </div>
              <div class="flex items-start gap-6">
                <div class="bg-tertiary/10 text-tertiary p-4 rounded-full">
                  <span class="material-symbols-outlined text-2xl" data-icon="mail">mail</span>
                </div>
                <div>
                  <p class="font-bold text-lg mb-1">Sähköposti</p>
                  {c.email1 && <a class="text-on-surface-variant hover:text-primary transition-colors underline decoration-primary/20 block break-all" href={`mailto:${c.email1}`}>{c.email1}</a>}
                  {c.email2 && <a class="text-on-surface-variant hover:text-primary transition-colors underline decoration-primary/20 block break-all" href={`mailto:${c.email2}`}>{c.email2}</a>}
                </div>
              </div>
              <div class="flex items-start gap-6">
                <div class="bg-secondary/10 text-secondary p-4 rounded-full">
                  <span class="material-symbols-outlined text-2xl" data-icon="call">call</span>
                </div>
                <div>
                  <p class="font-bold text-lg mb-1">Puhelin</p>
                  <a class="text-on-surface-variant hover:text-primary transition-colors font-mono" href={`tel:${(c.phone||'').replace(/\s/g,'')}`}>{c.phone}</a>
                </div>
              </div>
            </div>
          </section>

        </div>

        <!-- Farm Atmosphere -->
        <div class="relative overflow-hidden rounded-[2.5rem] aspect-square bg-primary/5 flex items-center justify-center">
          <div class="text-center px-8">
            <span class="material-symbols-outlined text-primary text-6xl mb-4 block">yard</span>
            <p class="font-headline font-black text-3xl italic tracking-tighter leading-tight text-on-surface">Siivekkäiden<br/>paratiisi.</p>
          </div>
        </div>
      </aside>

      <!-- CTA Side -->
      <section class="bg-surface-container rounded-[1.5rem] sm:rounded-[3rem] p-6 sm:p-8 md:p-16 border border-outline/5 reveal flex flex-col justify-center items-center text-center">
        <span class="material-symbols-outlined text-primary text-6xl mb-6">contact_support</span>
        <h2 class="font-headline text-2xl sm:text-3xl md:text-4xl font-black mb-4 italic tracking-tight">{c.page.ctaTitle}</h2>
        <p class="text-on-surface-variant text-lg mb-10 max-w-md">
          {c.page.ctaBody}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={`tel:${phoneLink}`} class="bg-primary text-on-primary px-8 py-4 rounded-full font-bold uppercase text-sm tracking-widest hover:brightness-110 transition-all shadow-xl flex items-center gap-3">
            <span class="material-symbols-outlined">call</span>
            {c.page.ctaCallButton}
          </a>
          <a href={`mailto:${c.email2}`} class="border-2 border-on-surface text-on-surface px-8 py-4 rounded-full font-bold uppercase text-sm tracking-widest hover:bg-on-surface hover:text-white transition-all flex items-center gap-3">
            <span class="material-symbols-outlined">mail</span>
            {c.page.ctaEmailButton}
          </a>
        </div>
      </section>
    </div>

    <!-- FAQ Section -->
    <section class="mt-40">
      <h2 class="font-headline text-2xl sm:text-3xl md:text-5xl font-black mb-12 sm:mb-16 text-center italic tracking-tight">{c.page.faqTitle}</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {c.page.faqs.map((faq: { question: string; answer: string }) => (
          <div class="bg-surface-container-low p-10 rounded-[2.5rem] border border-outline/5 hover:border-primary/20 transition-colors">
            <h3 class="font-headline font-black text-xl mb-4 italic text-primary">{faq.question}</h3>
            <p class="text-on-surface-variant leading-relaxed" set:html={faq.answer}></p>
          </div>
        ))}
      </div>
    </section>

    <!-- Locations Map Section -->
    <section class="mt-24 sm:mt-40 mb-20 bg-surface-container-high rounded-[1.5rem] sm:rounded-[3.5rem] overflow-hidden grid lg:grid-cols-2 items-stretch border border-outline/10">
      <div class="p-8 sm:p-12 md:p-20">
        <h2 class="font-headline text-2xl sm:text-3xl md:text-5xl font-black mb-8 italic tracking-tight">{c.page.mapTitle}</h2>
        <div class="space-y-10 mb-12">
          <p class="text-on-surface-variant text-lg leading-relaxed">
              {c.page.mapBody}
          </p>
          <div class="space-y-6">
            <div class="flex items-center gap-5 group">
              <span class="material-symbols-outlined text-primary bg-primary/10 p-3 rounded-full">location_on</span>
              <span class="font-bold">{c.street}, {c.city}</span>
            </div>
          </div>
        </div>
        <a class="inline-flex items-center gap-4 font-headline font-black text-primary tracking-widest uppercase italic group text-sm" href={mapDirUrl} target="_blank" rel="noopener noreferrer">
            Avaa navigointi
            <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_right_alt</span>
        </a>
      </div>
      <div class="min-h-[500px] bg-neutral-100 relative grayscale hover:grayscale-0 transition-all duration-1000 overflow-hidden shadow-inner">
        <iframe
          title="Siltajoen Sirkus Sijainti"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src={mapEmbedUrl}
          class="absolute inset-0 w-full h-full"
        ></iframe>
      </div>
    </section>
  </div>
</BaseLayout>
