---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout 
  title="Yhteystiedot" 
  description="Ota yhteyttä Siltajoen Sirkukseen. Löydät meidät Leppävedeltä ja Vaajakoskelta. Kysy lipuista, varaa esitys tai tarkista aukioloajat."
>
  <div class="px-6 max-w-7xl mx-auto pt-16">
    <!-- Hero Section -->
    <header class="mb-24 mt-10">
      <span class="text-primary font-bold uppercase tracking-[0.3em] text-xs mb-4 block">Esiripun Takana</span>
      <h1 class="font-headline text-5xl sm:text-6xl md:text-8xl font-black text-on-surface leading-tight mb-8 tracking-tighter italic">Ota Yhteyttä</h1>
      <p class="text-on-surface-variant text-xl md:text-2xl max-w-3xl leading-relaxed font-light">
          Onko sinulla kysyttävää lipuista, esityksistä tai eläimistä? Olemme täällä luomassa taikaa kanssasi.
      </p>
    </header>

    <!-- Contact Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start mb-24">
      <!-- Information Side -->
      <aside class="lg:col-span-5 space-y-12">
        <div class="bg-surface-container-low rounded-[2.5rem] p-12 space-y-12 border border-outline/5">
          <section>
            <h2 class="font-headline text-3xl font-black mb-8 italic tracking-tight">Yhteystiedot</h2>
            <div class="space-y-8">
              <div class="flex items-start gap-6">
                <div class="bg-primary/10 text-primary p-4 rounded-full">
                  <span class="material-symbols-outlined text-2xl" data-icon="location_on">location_on</span>
                </div>
                <div>
                  <p class="font-bold text-lg mb-1">Päämaja</p>
                  <address class="text-on-surface-variant not-italic leading-relaxed">Siltajoentie 2,<br/>41310 Leppävesi</address>
                </div>
              </div>
              <div class="flex items-start gap-6">
                <div class="bg-tertiary/10 text-tertiary p-4 rounded-full">
                  <span class="material-symbols-outlined text-2xl" data-icon="mail">mail</span>
                </div>
                <div>
                  <p class="font-bold text-lg mb-1">Sähköposti</p>
                  <a class="text-on-surface-variant hover:text-primary transition-colors underline decoration-primary/20 block break-all" href="mailto:siilo@siltajoensirkus.fi">siilo@siltajoensirkus.fi</a>
                  <a class="text-on-surface-variant hover:text-primary transition-colors underline decoration-primary/20 block break-all" href="mailto:marianne@siltajoensirkus.fi">marianne@siltajoensirkus.fi</a>
                </div>
              </div>
              <div class="flex items-start gap-6">
                <div class="bg-secondary/10 text-secondary p-4 rounded-full">
                  <span class="material-symbols-outlined text-2xl" data-icon="call">call</span>
                </div>
                <div>
                  <p class="font-bold text-lg mb-1">Puhelin</p>
                  <a class="text-on-surface-variant hover:text-primary transition-colors font-mono" href="tel:+358449750415">+358 44 975 0415</a>
                </div>
              </div>
            </div>
          </section>

          <section class="pt-10 border-t border-outline/10">
            <h3 class="font-headline text-xl font-bold mb-6 italic">Aukioloajat</h3>
            <div class="space-y-4 text-on-surface-variant font-medium">
              <div class="flex justify-between border-b border-outline/5 pb-2"><span>Maanantai - Perjantai</span> <span>09:00 - 18:00</span></div>
              <div class="flex justify-between border-b border-outline/5 pb-2"><span>Lauantai</span> <span>10:00 - 16:00</span></div>
              <div class="flex justify-between"><span>Sunnuntai</span> <span class="italic opacity-50">Suljettu</span></div>
            </div>
          </section>
        </div>

        <!-- Bird/Farm Themed Placeholder -->
        <div class="relative overflow-hidden rounded-[2.5rem] aspect-square bg-neutral-200">
          <img loading="lazy"  alt="Siltajoen sirkuksen tunnelmaa" class="w-full h-full object-cover grayscale opacity-60" src="/placeholder-magic.jpg" onerror="this.style.display='none'" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
          <div class="absolute bottom-10 left-10 text-white z-10">
            <p class="font-headline font-black text-3xl italic tracking-tighter leading-tight">Taikuus alkaa<br/>täältä.</p>
          </div>
        </div>
      </aside>

      <!-- Form Side -->
      <section class="lg:col-span-7 bg-surface-container rounded-[3rem] p-8 md:p-16 border border-outline/5">
        <div>
          <h2 class="font-headline text-3xl md:text-4xl font-black mb-12 italic tracking-tight">Lähetä viesti</h2>
          <form id="contactForm" class="space-y-10">
            <div class="space-y-3">
              <label class="font-bold text-xs uppercase tracking-widest text-on-surface/50 ml-4" for="name">Nimi</label>
              <input class="w-full bg-surface border-none rounded-full px-8 py-5 focus:ring-4 focus:ring-primary/10 transition-all placeholder:text-on-surface/30" name="name" id="name" placeholder="Nimesi tai yrityksesi nimi" type="text" required/>
            </div>
            <div class="space-y-3">
              <label class="font-bold text-xs uppercase tracking-widest text-on-surface/50 ml-4" for="email">Sähköposti</label>
              <input class="w-full bg-surface border-none rounded-full px-8 py-5 focus:ring-4 focus:ring-primary/10 transition-all placeholder:text-on-surface/30" name="email" id="email" placeholder="sähköposti@esimerkki.fi" type="email" required/>
            </div>
            <div class="space-y-3">
              <label class="font-bold text-xs uppercase tracking-widest text-on-surface/50 ml-4" for="message">Viesti</label>
              <textarea class="w-full bg-surface border-none rounded-[2rem] px-8 py-6 focus:ring-4 focus:ring-primary/10 transition-all placeholder:text-on-surface/30 resize-none" name="message" id="message" placeholder="Miten voimme auttaa?" rows="6" required></textarea>
            </div>
            <p id="formStatus" class="hidden text-sm font-bold text-primary ml-4"></p>
            <button id="submitBtn" class="w-full bg-primary text-on-primary font-headline font-black tracking-[0.2em] py-6 rounded-full hover:bg-primary-dim transition-all shadow-2xl shadow-primary/30 flex justify-center items-center gap-3 uppercase text-sm italic" type="submit">
              <span class="material-symbols-outlined" data-icon="send">send</span>
              Lähetä viesti
            </button>
          </form>

          <script>
            const form = document.getElementById('contactForm');
            const statusLabel = document.getElementById('formStatus');
            const submitBtn = document.getElementById('submitBtn');

            form.addEventListener('submit', async (e) => {
              e.preventDefault();
              statusLabel.classList.remove('hidden');
              statusLabel.innerText = 'Lähetetään...';
              submitBtn.disabled = true;

              try {
                const formData = new FormData(form);
                formData.append('type', 'contact');
                const response = await fetch('/api/contact', {
                  method: 'POST',
                  body: formData,
                });
                const result = await response.json();
                
                if (result.success) {
                  statusLabel.innerText = result.message;
                  statusLabel.className = 'text-sm font-bold text-tertiary ml-4';
                  form.reset();
                } else {
                  throw new Error(result.message);
                }
              } catch (err) {
                statusLabel.innerText = err.message || 'Hups, jotain meni pieleen.';
                statusLabel.className = 'text-sm font-bold text-primary ml-4';
              } finally {
                submitBtn.disabled = false;
              }
            });
          </script>
        </div>
      </section>
    </div>

    <!-- FAQ Section -->
    <section class="mt-40">
      <h2 class="font-headline text-3xl md:text-5xl font-black mb-16 text-center italic tracking-tight">Usein Kysytyt Kysymykset</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-surface-container-low p-10 rounded-[2.5rem] border border-outline/5 hover:border-primary/20 transition-colors">
          <h3 class="font-headline font-black text-xl mb-4 italic text-primary">Missä tilanne sijaitsee?</h3>
          <p class="text-on-surface-variant leading-relaxed">Päätoimipisteemme on Siltajoella, mutta meillä on kiinteät noutopisteet myös <strong>Leppävedellä</strong> ja <strong>Vaajakoskella</strong>.</p>
        </div>
        <div class="bg-surface-container-low p-10 rounded-[2.5rem] border border-outline/5 hover:border-primary/20 transition-colors">
          <h3 class="font-headline font-black text-xl mb-4 italic text-primary">Miten varaan liput?</h3>
          <p class="text-on-surface-variant leading-relaxed">Voit ostaa liput suoraan verkkokaupastamme tai varata ne puhelimitse. Ryhmävaraukset onnistuvat parhaiten yllä olevalla lomakkeella.</p>
        </div>
        <div class="bg-surface-container-low p-10 rounded-[2.5rem] border border-outline/5 hover:border-primary/20 transition-colors">
          <h3 class="font-headline font-black text-xl mb-4 italic text-primary">Onko toimipisteissä pysäköintiä?</h3>
          <p class="text-on-surface-variant leading-relaxed">Kyllä, kaikissa kolmessa toimipisteessämme on runsaasti ilmaista pysäköintitilaa asiakkaillemme.</p>
        </div>
        <div class="bg-surface-container-low p-10 rounded-[2.5rem] border border-outline/5 hover:border-primary/20 transition-colors">
          <h3 class="font-headline font-black text-xl mb-4 italic text-primary">Noutopisteet ja lipunmyynti?</h3>
          <p class="text-on-surface-variant leading-relaxed">Eläimiä ja rehuja voi noutaa ennakkoon sovitusti Leppäveden ja Vaajakosken noutopisteiltämme arkisin aukioloaikojen puitteissa.</p>
        </div>
      </div>
    </section>

    <!-- Locations Map Section -->
    <section class="mt-40 mb-20 bg-surface-container-high rounded-[3.5rem] overflow-hidden grid lg:grid-cols-2 items-stretch border border-outline/10">
      <div class="p-12 md:p-20">
        <h2 class="font-headline text-3xl md:text-5xl font-black mb-8 italic tracking-tight">Löydät meidät täältä</h2>
        <div class="space-y-10 mb-12">
          <p class="text-on-surface-variant text-lg leading-relaxed">
              Siltajoen Sirkuskylä sijaitsee upean luonnon helmassa Keski-Suomessa.
          </p>
          <div class="space-y-6">
            <div class="flex items-center gap-5 group">
              <span class="material-symbols-outlined text-primary bg-primary/10 p-3 rounded-full">location_on</span>
              <span class="font-bold">Päämaja & Treenitila: Siltajoentie 2, 41310 Leppävesi</span>
            </div>
          </div>
        </div>
        <a class="inline-flex items-center gap-4 font-headline font-black text-primary tracking-widest uppercase italic group text-sm" href="https://www.google.com/maps/dir/?api=1&destination=Siltajoentie+2+Leppavesi" target="_blank">
            Avaa navigointi
            <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_right_alt</span>
        </a>
      </div>
      <div class="min-h-[500px] bg-neutral-100 relative grayscale hover:grayscale-0 transition-all duration-1000 overflow-hidden shadow-inner">
        <iframe 
          title="Siltajoen Sirkus Sijainti"
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1872.4820625624775!2d25.8927014!3d62.2963625!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4685718df2bf6a97%3A0x6a97f2bf6a97f2bf!2sSiltajoentie%202%2C%2041310%20Laukaa!5e0!3m2!1sfi!2sfi!4v1711200000000!5m2!1sfi!2sfi"
          class="absolute inset-0 w-full h-full"
        ></iframe>
      </div>
    </section>
  </div>
</BaseLayout>
