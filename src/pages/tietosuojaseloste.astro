---
import BaseLayout from "../layouts/BaseLayout.astro";
import privacyDataRaw from "../data/privacy.json";
const p = privacyDataRaw as any;
---

<BaseLayout
  title={p.title}
  description="Siltajoen Sirkuksen tietosuojaseloste ja rekisteriseloste."
>
  <div class="px-6 max-w-4xl mx-auto pt-40 pb-24">
    <h1 class="font-headline text-4xl sm:text-5xl md:text-6xl font-black mb-12 italic tracking-tighter text-primary">{p.title}</h1>
    <article class="prose prose-lg dark:prose-invert max-w-none space-y-8 text-on-surface-variant">

      {p.sections.map((section: { title: string; body: string; list?: string[] }) => (
        <section>
          <h2 class="font-headline text-2xl font-bold text-on-surface mb-4">{section.title}</h2>
          <p set:html={section.body}></p>
          {section.list && section.list.length > 0 && (
            <ul class="list-disc pl-6 space-y-2">
              {section.list.map((item: string) => (
                <li set:html={item}></li>
              ))}
            </ul>
          )}
        </section>
      ))}

    </article>
  </div>
</BaseLayout>
