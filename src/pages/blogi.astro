---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout 
  title="Blogi" 
  description="Lue Siltajoen Sirkuksen uusimmat kuulumiset, uutiset ja tarinat."
>
  <!-- Hero-osio -->
  <section class="max-w-7xl mx-auto px-8 mb-20 pt-16">
    <div class="flex flex-col md:flex-row items-end justify-between gap-8">
      <div class="max-w-2xl">
        <span class="text-secondary font-bold tracking-widest uppercase text-sm mb-4 block">SIRKUSKUULUMISIA</span>
        <h1 class="text-6xl md:text-8xl font-black text-on-surface leading-[0.9] mb-8">Uutisia ja <span class="text-primary italic">vinkkejä</span>.</h1>
        <p class="text-xl text-on-surface-variant leading-relaxed font-medium">
            Sukella esiriipun taakse. Täältä löydät uusimmat uutiset Siltajoelta, vinkkejä lintujen hoitoon ja tarinoita meidän upeasta tiimistämme.
        </p>
      </div>
      <div class="hidden lg:block pb-4">
        <div class="w-24 h-24 rounded-full border-4 border-dashed border-primary/30 flex items-center justify-center animate-spin-slow">
          <span class="material-symbols-outlined text-primary text-4xl" data-icon="star">star</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Blogi-ruudukko -->
  <section class="max-w-7xl mx-auto px-8">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
      <!-- Pääartikkeli -->
      <article class="md:col-span-8 group cursor-pointer">
        <div class="relative overflow-hidden rounded-lg aspect-[16/9] mb-6 bg-surface-container">
          <img loading="lazy"  alt="Sirkusareena valoissa" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="/placeholder-news.jpg" onerror="this.style.display='none'"/>
          <div class="absolute top-6 left-6">
            <span class="bg-tertiary-container text-on-tertiary-container px-4 py-2 rounded-full text-sm font-bold border border-tertiary/20">UUTINEN</span>
          </div>
        </div>
        <div class="flex items-center gap-4 mb-4">
          <span class="text-on-surface-variant font-medium text-sm">15. Toukokuuta, 2026</span>
          <div class="h-px flex-1 bg-outline-variant/30"></div>
        </div>
        <h2 class="text-4xl font-bold mb-4 group-hover:text-primary transition-colors"><a href="#">Siltajoen kesäkauden aikataulu on julkaistu!</a></h2>
        <p class="text-on-surface-variant line-clamp-2 text-lg">Tänä kesänä otamme vastaan vierailijoita uusin aukioloin. Katso kaikki pysähdyspaikkamme ja valmistaudu tapaamaan uusia kanarotujamme.</p>
      </article>

      <!-- Sivupalkin artikkelit -->
      <div class="md:col-span-4 flex flex-col gap-12">
        <article class="group cursor-pointer">
          <div class="aspect-video rounded-lg overflow-hidden mb-4 bg-surface-container">
            <img loading="lazy"  alt="Sirkuslintu" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="/placeholder-tips.jpg" onerror="this.style.display='none'"/>
          </div>
          <span class="text-secondary font-bold text-xs tracking-wider uppercase mb-2 block">VINKIT</span>
          <h3 class="text-xl font-bold group-hover:text-primary transition-colors"><a href="#">5 vinkkiä kanojen talvihoitoon</a></h3>
        </article>
        <article class="group cursor-pointer">
          <div class="aspect-video rounded-lg overflow-hidden mb-4 bg-surface-container">
            <img loading="lazy"  alt="Lintu luonnossa" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="/placeholder-story.jpg" onerror="this.style.display='none'"/>
          </div>
          <span class="text-secondary font-bold text-xs tracking-wider uppercase mb-2 block">TARINAT</span>
          <h3 class="text-xl font-bold group-hover:text-primary transition-colors"><a href="#">Elämää maalla: Siltajoen arki</a></h3>
        </article>
      </div>

      <!-- Bento-ruudukon alaosa -->
      <div class="md:col-span-12 grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
        <div class="bg-surface-container-low p-8 rounded-lg flex flex-col justify-between group hover:bg-surface-container transition-colors">
          <div>
            <div class="w-12 h-12 rounded-xl bg-primary-container flex items-center justify-center mb-6">
              <span class="material-symbols-outlined text-on-primary-container" data-icon="auto_awesome">auto_awesome</span>
            </div>
            <h3 class="text-2xl font-bold mb-4">Miten aloittaa kanojen pito?</h3>
            <p class="text-on-surface-variant">Aloita näillä helpoilla askelilla. Ammattilaisemme neuvoo!</p>
          </div>
          <div class="mt-8">
            <span class="text-primary font-bold flex items-center gap-2 group-hover:gap-4 transition-all">Lue lisää <span class="material-symbols-outlined" data-icon="arrow_forward">arrow_forward</span></span>
          </div>
        </div>

        <!-- Blogger-nosto -->
        <div class="md:col-span-2 bg-gradient-to-br from-primary to-primary-dim p-12 rounded-lg relative overflow-hidden flex flex-col md:flex-row items-center gap-8">
          <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full -mr-20 -mt-20 blur-3xl"></div>
          <div class="relative z-10 flex-1">
            <h2 class="text-4xl font-bold text-on-primary mb-4 leading-tight">Haluatko lukea lisää tarinoita?</h2>
            <p class="text-on-primary/80 text-lg mb-8">Päivitämme ahkerasti virallista blogiamme, josta löydät laajemmat jutut ja historialliset arkistot.</p>
            <a class="inline-flex items-center gap-3 bg-surface text-primary px-8 py-4 rounded-xl font-black text-lg hover:scale-105 transition-transform duration-200 active:scale-95 shadow-xl uppercase tracking-tight" href="https://siltajoensirkus.blogspot.com/" target="_blank">
              <span class="material-symbols-outlined" data-icon="rss_feed">rss_feed</span>
              Siirry Bloggeriin
            </a>
          </div>
          <div class="relative z-10 hidden md:block w-48 h-48 bg-white/10 backdrop-blur-md rounded-2xl flex items-center justify-center transform rotate-6 border border-white/20">
            <span class="material-symbols-outlined text-white text-7xl" data-icon="edit_note">edit_note</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Uutiskirje-osio -->
  <section class="max-w-7xl mx-auto px-8 mt-32 mb-10">
    <div class="bg-surface-container-highest rounded-lg p-12 flex flex-col items-center text-center">
      <span class="text-secondary font-bold tracking-widest uppercase text-sm mb-4">UUTISKIRJE</span>
      <h2 class="text-4xl md:text-5xl font-bold mb-6">Tilaa uutiset suoraan <span class="text-primary italic">sähköpostiisi</span>.</h2>
      <p class="max-w-lg text-on-surface-variant mb-10 text-lg">Ole ensimmäinen, joka kuulee myyntiin tulevista linnuista.</p>
      <form id="newsletterForm" class="flex flex-col md:flex-row w-full max-w-xl gap-4">
        <input class="flex-1 bg-surface-container-lowest border-none rounded-xl px-6 py-4 focus:ring-2 focus:ring-primary-fixed outline-none text-lg" name="email" placeholder="Sähköpostiosoitteesi" type="email" required/>
        <button id="newsletterBtn" type="submit" class="bg-primary text-on-primary px-10 py-4 rounded-xl font-bold hover:bg-primary-dim transition-colors">Tilaa nyt</button>
      </form>
      <p id="newsletterStatus" class="mt-4 font-bold text-sm hidden"></p>
    </div>
  </section>

  <script>
    const form = document.getElementById('newsletterForm');
    const statusLabel = document.getElementById('newsletterStatus');
    const submitBtn = document.getElementById('newsletterBtn');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      statusLabel.classList.remove('hidden');
      statusLabel.innerText = 'Tilataan...';
      submitBtn.disabled = true;

      try {
        const formData = new FormData(form);
        formData.append('type', 'newsletter');
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });
        const result = await response.json();
        
        if (result.success) {
          statusLabel.innerText = result.message;
          statusLabel.className = 'mt-4 text-sm font-bold text-tertiary';
          form.reset();
        } else {
          throw new Error(result.message);
        }
      } catch (err) {
        statusLabel.innerText = err.message || 'Hups, jotain meni pieleen.';
        statusLabel.className = 'mt-4 text-sm font-bold text-primary';
      } finally {
        submitBtn.disabled = false;
      }
    });
  </script>
</BaseLayout>
