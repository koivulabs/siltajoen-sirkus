---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import blogDataRaw from "../data/blog.json";
import { getAsset } from "../utils/assets";
const blogData = blogDataRaw as any;

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/kuvia/*.{jpeg,jpg,png,gif,JPG}', { eager: true });
const getImg = (path: string) => getAsset(path, images);
---

<BaseLayout
  title="Blogi"
  description="Tilan tarinat - Seuraa Siltajoen Sirkuksen arkea, vinkkejä ja uutisia lintutilalta."
>
  <!-- Hero Section -->
  <header class="max-w-7xl mx-auto px-8 pt-16 mb-20 reveal">
    <span class="text-primary font-bold tracking-[0.2em] uppercase text-xs mb-4 block">{blogData.heroSubtitle}</span>
    <h1 class="text-4xl sm:text-5xl md:text-8xl font-black leading-[0.9] tracking-tighter mb-8 uppercase italic">{blogData.heroTitle}</h1>
    <p class="text-xl text-on-surface/60 max-w-2xl leading-relaxed">
      {blogData.heroBody}
    </p>
  </header>

  <!-- Posts Grid -->
  <div class="max-w-7xl mx-auto px-8 space-y-24">
    {blogData.posts.map((post: any, index: number) => (
      <article class={`blog-post reveal group cursor-pointer ${post.featured ? 'col-span-full border-b-4 border-on-surface pb-16' : ''}`} data-index={index}>
        <div class={`flex flex-col ${post.featured ? 'lg:flex-row' : 'lg:flex-row'} gap-12`}>
          <!-- Image Section -->
          <div class={`${post.featured ? 'lg:w-2/3' : 'lg:w-1/3 text-sm'} aspect-video lg:aspect-square bg-neutral-200 rounded-[2.5rem] overflow-hidden relative border border-outline/10`}>
            {post.images && post.images.length > 0 ? (
              getImg(post.images[0]) ? (
                <Image
                  src={getImg(post.images[0])!}
                  alt={post.title}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  style={`object-position: ${post.focalX ?? 50}% ${post.focalY ?? 50}%`}
                  width={800}
                  height={600}
                  loading={index < 3 ? "eager" : "lazy"}
                />
              ) : (
                <img
                  src={post.images[0]}
                  alt={post.title}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  style={`object-position: ${post.focalX ?? 50}% ${post.focalY ?? 50}%`}
                  loading={index < 3 ? "eager" : "lazy"}
                />
              )
            ) : (
                <div class="absolute inset-0 flex items-center justify-center text-neutral-400">
                    <span class="material-symbols-outlined text-6xl">image</span>
                </div>
            )}
            <div class="absolute top-6 left-6 flex gap-2">
                 <span class="bg-white/90 backdrop-blur-md px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest shadow-sm">
                    {post.category}
                </span>
            </div>
          </div>

          <!-- Content Section -->
          <div class={`flex-1 flex flex-col justify-center ${post.featured ? 'lg:py-8' : 'py-4'}`}>
            <time class="text-xs font-bold text-primary mb-4 block uppercase tracking-widest">{post.date}</time>
            <h2 class={`${post.featured ? 'text-4xl md:text-6xl' : 'text-3xl'} font-black uppercase italic leading-none mb-6 group-hover:text-primary transition-colors tracking-tighter`}>
                {post.title}
            </h2>
            <p class="text-on-surface/60 text-lg leading-relaxed mb-8 line-clamp-3">
              {post.excerpt}
            </p>
            <div class="flex items-center gap-4 text-sm font-black uppercase tracking-widest group-hover:gap-6 transition-all">
                Lue koko tarina <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </div>
          </div>
        </div>

        <!-- Expanded View (Hidden by default) -->
        <div class="post-content hidden mt-16 space-y-12">
           <div class="prose prose-xl prose-neutral max-w-4xl mx-auto">
             {post.body ? post.body.split('\n\n').map((p: string) => (
                <p class="mb-6 text-on-surface/80 leading-relaxed font-body">{p}</p>
             )) : <p class="italic text-on-surface/40">Tämä tarina odottaa vielä kirjoittajaansa...</p>}
           </div>

           <!-- Gallery -->
           {post.images && post.images.length > 1 && (
             <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
                {post.images.slice(1).map((img: string) => (
                  <div class="aspect-square bg-neutral-100 rounded-[3rem] overflow-hidden border-8 border-white shadow-xl rotate-1 hover:rotate-0 transition-transform duration-500">
                    {getImg(img) ? (
                      <Image 
                        src={getImg(img)!} 
                        alt="" 
                        class="w-full h-full object-cover" 
                        width={600} 
                        height={600} 
                      />
                    ) : (
                      <img src={img} alt="" class="w-full h-full object-cover" loading="lazy" />
                    )}
                  </div>
                ))}
             </div>
           )}

           <!-- Post CRO Section -->
           <div class="bg-surface-container rounded-[3rem] p-12 md:p-20 mt-20 text-center border border-outline/10">
              <h3 class="text-3xl md:text-5xl font-black uppercase italic mb-6 leading-tight">Haluatko samanlaista taikaa kotiisi?</h3>
              <p class="text-lg text-on-surface/60 mb-10 max-w-xl mx-auto">Tutustu myytäviin eläimiimme ja luo oma sirkuksesi.</p>
              <div class="flex flex-wrap justify-center gap-6">
                 <a href="/elaimet" class="bg-primary text-on-primary px-10 py-4 rounded-full font-bold uppercase text-xs tracking-widest hover:brightness-110 transition-all shadow-xl">Katso myytävät eläimet</a>
                 <a href={blogData.bloggerUrl} target="_blank" rel="noopener noreferrer" class="border-2 border-on-surface px-10 py-4 rounded-full font-bold uppercase text-xs tracking-widest hover:bg-on-surface hover:text-white transition-all">Vanhemmat jutut arkistossa</a>
              </div>
           </div>
        </div>
      </article>
    ))}
  </div>

  <!-- Blogger Archive Footer CTA -->
  <footer class="max-w-7xl mx-auto px-8 mt-32 mb-16 reveal">
    <div class="border-t-2 border-on-surface/10 pt-16 flex flex-col md:flex-row items-center justify-between gap-12">
       <div class="max-w-md">
           <h3 class="text-2xl font-black uppercase italic mb-4 tracking-tight">Kaikki tarinat yhdessä paikassa</h3>
           <p class="text-on-surface/60">Siltajoen Sirkuksen blogia on pidetty Bloggerissa jo vuosia. Pääset selaamaan koko arkistoa tästä.</p>
       </div>
       <a href={blogData.bloggerUrl} target="_blank" rel="noopener noreferrer" class="w-full md:w-auto bg-zinc-900 text-white px-12 py-6 rounded-full font-black uppercase tracking-widest text-sm hover:bg-primary transition-all text-center">
            Arkistoon (Blogger) →
       </a>
    </div>
  </footer>

  <script>
    const posts = document.querySelectorAll('.blog-post');
    posts.forEach(post => {
      post.addEventListener('click', () => {
        const content = post.querySelector('.post-content');
        const isHidden = content?.classList.contains('hidden');
        
        // Toggle this post
        content?.classList.toggle('hidden');
        
        if (isHidden) {
          // Scroll to post top with offset for header
          const y = post.getBoundingClientRect().top + window.pageYOffset - 100;
          window.scrollTo({ top: y, behavior: 'smooth' });
        }
      });
    });
  </script>
</BaseLayout>
