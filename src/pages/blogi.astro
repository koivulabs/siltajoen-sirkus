---
import BaseLayout from "../layouts/BaseLayout.astro";
import blogDataRaw from "../data/blog.json";
const blogData = blogDataRaw as any;

const featured = blogData.posts.find((p: any) => p.featured);
const rest = blogData.posts.filter((p: any) => !p.featured);
---

<BaseLayout
  title="Tilan Tarinat"
  description="Siltajoen Sirkuksen tilan tarinat – kuulumiset, vinkit ja arki suoraan lintutilalta."
>
  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-8 pt-20 pb-12">
    <div class="flex flex-col md:flex-row items-end justify-between gap-8">
      <div class="max-w-2xl">
        <span class="text-primary font-bold tracking-[0.2em] uppercase text-xs mb-4 block">Siltajoen Sirkus</span>
        <h1 class="text-4xl sm:text-5xl md:text-8xl font-black leading-[0.9] tracking-tighter mb-6 uppercase italic">
          {blogData.heroTitle}.
        </h1>
        <p class="text-xl text-on-surface-variant leading-relaxed mb-2 font-medium italic">
          {blogData.heroSubtitle}
        </p>
        <p class="text-lg text-on-surface/60 leading-relaxed max-w-xl">
          {blogData.heroBody}
        </p>
      </div>
      <div class="hidden lg:flex flex-col items-center gap-2 pb-4">
        <div class="w-20 h-20 rounded-full border-4 border-dashed border-primary/30 flex items-center justify-center animate-spin-slow">
          <span class="material-symbols-outlined text-primary text-3xl">nest_clock_farsight_analog</span>
        </div>
        <span class="text-xs text-on-surface/30 uppercase tracking-widest">Arki</span>
      </div>
    </div>
  </section>

  <!-- Featured post -->
  {featured && (
    <section class="max-w-7xl mx-auto px-8 mb-16">
      <article
        class="relative overflow-hidden rounded-[2.5rem] bg-surface border border-outline/10 shadow-2xl cursor-pointer group story-card"
        data-slug={featured.slug}
        onclick={`toggleStory('${featured.slug}')`}
      >
        <!-- Cover image -->
        <div class="relative aspect-[21/9] overflow-hidden">
          <img
            loading="lazy"
            src={featured.images?.[0] || ''}
            alt={featured.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            style={`object-position: ${featured.focalX ?? 50}% ${featured.focalY ?? 50}%`}
            onerror="this.style.display='none'"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
          <div class="absolute top-8 left-8">
            <span class="bg-primary text-on-primary px-4 py-2 rounded-full text-xs font-bold tracking-widest uppercase">{featured.category}</span>
          </div>
          <div class="absolute bottom-8 left-8 right-8">
            <p class="text-white/60 text-sm mb-2">{featured.date}</p>
            <h2 class="text-3xl md:text-5xl font-black text-white leading-tight mb-2 uppercase tracking-tight italic">{featured.title}</h2>
            <p class="text-white/70 text-lg line-clamp-2 max-w-2xl">{featured.excerpt}</p>
          </div>
          <div class="absolute bottom-8 right-8">
            <div class="w-12 h-12 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center text-white transition-transform group-hover:scale-110" id={`arrow-${featured.slug}`}>
              <span class="material-symbols-outlined">expand_more</span>
            </div>
          </div>
        </div>

        <!-- Expandable body -->
        <div class="story-body max-h-0 overflow-hidden transition-all duration-500" id={`body-${featured.slug}`}>
          <div class="p-8 md:p-12">
            <div class="max-w-3xl">
              {featured.body && featured.body.split('\n\n').map((para: string) => (
                <p class="text-on-surface/80 leading-relaxed text-lg mb-6">{para}</p>
              ))}
            </div>
            {featured.images && featured.images.length > 1 && (
              <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mt-8">
                {featured.images.slice(1).map((img: string) => (
                  <div class="aspect-square rounded-2xl overflow-hidden">
                    <img loading="lazy" src={img} alt="" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </article>
    </section>
  )}

  <!-- Rest of posts -->
  {rest.length > 0 && (
    <section class="max-w-7xl mx-auto px-8 mb-24">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {rest.map((post: any) => (
          <article
            class="bg-surface border border-outline/10 rounded-[2rem] overflow-hidden shadow-lg cursor-pointer group story-card"
            data-slug={post.slug}
            onclick={`toggleStory('${post.slug}')`}
          >
            <!-- Image -->
            {post.images?.[0] && (
              <div class="aspect-video overflow-hidden">
                <img
                  loading="lazy"
                  src={post.images[0]}
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  style={`object-position: ${post.focalX ?? 50}% ${post.focalY ?? 50}%`}
                  onerror="this.style.display='none'"
                />
              </div>
            )}
            <!-- Header always visible -->
            <div class="p-8">
              <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3">
                  <span class="text-primary font-bold text-xs tracking-widest uppercase">{post.category}</span>
                  <span class="text-on-surface/30 text-xs">·</span>
                  <span class="text-on-surface/40 text-sm">{post.date}</span>
                </div>
                <div class="w-8 h-8 rounded-full border border-outline/30 flex items-center justify-center text-on-surface/40 transition-transform group-hover:border-primary/50" id={`arrow-${post.slug}`}>
                  <span class="material-symbols-outlined text-lg">expand_more</span>
                </div>
              </div>
              <h3 class="text-2xl font-black uppercase italic tracking-tight mb-3 group-hover:text-primary transition-colors">{post.title}</h3>
              <p class="text-on-surface/60 leading-relaxed">{post.excerpt}</p>
            </div>

            <!-- Expandable body -->
            <div class="story-body max-h-0 overflow-hidden transition-all duration-500" id={`body-${post.slug}`}>
              <div class="px-8 pb-8">
                <div class="border-t border-outline/10 pt-8">
                  {post.body && post.body.split('\n\n').map((para: string) => (
                    <p class="text-on-surface/70 leading-relaxed mb-4">{para}</p>
                  ))}
                  {post.images && post.images.length > 1 && (
                    <div class="grid grid-cols-2 gap-3 mt-6">
                      {post.images.slice(1).map((img: string) => (
                        <div class="aspect-video rounded-xl overflow-hidden">
                          <img loading="lazy" src={img} alt="" class="w-full h-full object-cover" />
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- Blogger archive link -->
  <section class="max-w-7xl mx-auto px-8 mb-24">
    <div class="border border-outline/20 rounded-2xl p-8 flex flex-col sm:flex-row items-center justify-between gap-6 bg-surface">
      <div>
        <p class="text-on-surface/40 text-sm uppercase tracking-widest font-bold mb-1">Arkisto</p>
        <p class="text-on-surface/70">Vanhemmat tarinat ja blogipostaukset löytyvät Bloggerista →</p>
      </div>
      <a
        href={blogData.bloggerUrl}
        target="_blank"
        rel="noopener"
        class="whitespace-nowrap px-6 py-3 border border-outline/30 rounded-full text-sm font-bold text-on-surface/60 hover:border-primary/50 hover:text-primary transition-all"
      >
        Avaa Blogger-arkisto ↗
      </a>
    </div>
  </section>

  <script>
    function toggleStory(slug: string) {
      const body = document.getElementById(`body-${slug}`);
      const arrow = document.getElementById(`arrow-${slug}`);
      const icon = arrow?.querySelector('.material-symbols-outlined');
      if (!body) return;
      const isOpen = body.style.maxHeight && body.style.maxHeight !== '0px';
      if (isOpen) {
        body.style.maxHeight = '0px';
        if (icon) icon.textContent = 'expand_more';
        arrow?.style.setProperty('transform', '');
      } else {
        body.style.maxHeight = body.scrollHeight + 2000 + 'px';
        if (icon) icon.textContent = 'expand_less';
      }
    }
    (window as any).toggleStory = toggleStory;
  </script>
</BaseLayout>
