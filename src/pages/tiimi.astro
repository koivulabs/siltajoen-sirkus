---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout 
  title="Tiimi" 
  description="Tutustu Siltajoen Sirkuksen sydämeen. Täältä löydät sirkusperheemme jäsenet, tirehtööristä huoltojoukkoihin."
>
  <!-- Hero Section -->
  <header class="max-w-7xl mx-auto px-8 mb-20 text-center pt-16">
    <span class="text-primary font-bold tracking-[0.2em] uppercase text-xs mb-4 block">Sirkusperheemme</span>
    <h1 class="text-4xl sm:text-5xl md:text-8xl font-black leading-[0.9] tracking-tighter mb-8 uppercase italic">Konkkaronkka</h1>
    <p class="text-xl text-on-surface/60 max-w-2xl mx-auto leading-relaxed">
        Siltajoen Sirkus on enemmän kuin pelkkä paikka – se on unelmoijien, akrobaattien ja eläinystävien yhteinen koti. Tutustu ihmisiin, jotka pitävät huolen tilasta ja linnuista joka päivä.
    </p>
  </header>

  <!-- Personnel Grid -->
  <section class="max-w-7xl mx-auto px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      <!-- Marianne -->
      <article class="group">
        <div class="aspect-[4/5] bg-neutral-200 rounded-[2rem] mb-6 flex items-center justify-center p-8 text-center border border-outline overflow-hidden relative">
          <img loading="lazy"  src="/placeholder-marianne.jpg" alt="Marianne" class="absolute inset-0 w-full h-full object-cover" onerror="this.style.display='none'" />
          <span class="text-neutral-500 font-medium uppercase tracking-wider text-sm z-10 relative bg-white/50 backdrop-blur-sm px-4 py-2 rounded-xl">Kuva: Marianne</span>
        </div>
        <div class="px-2">
          <h3 class="text-3xl font-black uppercase italic mb-1 tracking-tight">Marianne</h3>
          <div class="text-primary font-bold text-xs mb-4 uppercase tracking-[0.2em]">Tirehtööri</div>
          <p class="text-on-surface/70 text-sm leading-relaxed mb-6">
              Sirkuksen sielu ja johtaja, joka pitää huolen siitä, että karavaani kulkee ja jokainen tuntee olonsa kotoisaksi.
          </p>
          <div class="flex items-center gap-2 text-sm font-bold">
            <span class="material-symbols-outlined text-primary text-lg">call</span>
            <a class="hover:text-primary transition-colors" href="tel:0449750415">044 975 0415</a>
          </div>
        </div>
      </article>

      <!-- Markko -->
      <article class="group">
        <div class="aspect-[4/5] bg-neutral-200 rounded-[2rem] mb-6 flex items-center justify-center p-8 text-center border border-outline overflow-hidden relative">
          <img loading="lazy"  src="/placeholder-markko.jpg" alt="Markko" class="absolute inset-0 w-full h-full object-cover" onerror="this.style.display='none'" />
          <span class="text-neutral-500 font-medium uppercase tracking-wider text-sm z-10 relative bg-white/50 backdrop-blur-sm px-4 py-2 rounded-xl">Kuva: Markko</span>
        </div>
        <div class="px-2">
          <h3 class="text-3xl font-black uppercase italic mb-1 tracking-tight">Markko</h3>
          <div class="text-primary font-bold text-xs mb-4 uppercase tracking-[0.2em]">Tekniikka &amp; Huolto</div>
          <p class="text-on-surface/70 text-sm leading-relaxed mb-6">
              Mies, joka saa teltan pystyyn ja valot syttymään. Markko on paikalla ensimmäisenä ja lähtee viimeisenä.
          </p>
          <div class="flex items-center gap-2 text-sm font-bold">
            <span class="material-symbols-outlined text-primary text-lg">alternate_email</span>
            <span class="text-on-surface/50">markko@siltajoensirkus.fi</span>
          </div>
        </div>
      </article>

      <!-- Ansa -->
      <article class="group">
        <div class="aspect-[4/5] bg-neutral-200 rounded-[2rem] mb-6 flex items-center justify-center p-8 text-center border border-outline overflow-hidden relative">
          <img loading="lazy"  src="/placeholder-ansa.jpg" alt="Ansa" class="absolute inset-0 w-full h-full object-cover" onerror="this.style.display='none'" />
          <span class="text-neutral-500 font-medium uppercase tracking-wider text-sm z-10 relative bg-white/50 backdrop-blur-sm px-4 py-2 rounded-xl">Kuva: Ansa</span>
        </div>
        <div class="px-2">
          <h3 class="text-3xl font-black uppercase italic mb-1 tracking-tight">Ansa</h3>
          <div class="text-primary font-bold text-xs mb-4 uppercase tracking-[0.2em]">Somettaja</div>
          <p class="text-on-surface/70 text-sm leading-relaxed mb-6">
              Sirkuksen visuaalinen ääni maailmalle. Ansa vastaa siitä, että jokainen temppu ja tunnelma välittyy verkon yli aitoina ja puhuttelevina tarinoina.
          </p>
        </div>
      </article>

      <!-- Placeholder -->
      <article class="group">
        <div class="aspect-[4/5] bg-neutral-100 rounded-[2rem] mb-6 flex items-center justify-center p-8 text-center border border-dashed border-outline overflow-hidden relative">
          <span class="text-neutral-400 font-medium uppercase tracking-wider text-sm italic">Lisää konkkaronkkaa tulossa...</span>
        </div>
        <div class="px-2 opacity-40">
          <h3 class="text-3xl font-black uppercase italic mb-1 tracking-tight">Tulossa pian</h3>
          <div class="text-primary font-bold text-xs mb-4 uppercase tracking-[0.2em]">Asiantuntijat</div>
          <p class="text-on-surface/70 text-sm leading-relaxed mb-6">
              Päivitämme parhaillaan koko tiimimme esittelyitä. Pysy kuulolla!
          </p>
        </div>
      </article>
    </div>
  </section>

  <!-- Info Banner -->
  <section class="max-w-7xl mx-auto px-8 mt-32 mb-10">
    <div class="bg-surface-container rounded-[3rem] p-12 md:p-20 flex flex-col md:flex-row items-center justify-between gap-12 border border-outline">
      <div class="max-w-xl">
        <h2 class="text-3xl md:text-5xl font-black uppercase italic mb-6 leading-none">Haluatko osaksi porukkaa?</h2>
        <p class="text-lg text-on-surface/60 mb-8">Etsimme jatkuvasti uusia kykyjä ja reippaita käsipareja sirkusperheeseemme. Jos lintumaailma ja sirkuselämä houkuttelee, ota yhteyttä!</p>
        <div class="flex flex-wrap gap-4">
          <a class="bg-on-surface text-white px-8 py-4 rounded-full font-bold uppercase text-sm hover:bg-on-surface/80 transition-all" href="mailto:rekry@siltajoensirkus.fi">Lähetä hakemus</a>
          <a class="border border-on-surface text-on-surface px-8 py-4 rounded-full font-bold uppercase text-sm hover:bg-on-surface/5 transition-all" href="tel:0449750415">Soita Marianelle</a>
        </div>
      </div>
      <div class="w-full md:w-1/3 aspect-square bg-neutral-200 rounded-[2rem] flex items-center justify-center text-center p-4 relative overflow-hidden">
        <img loading="lazy"  src="/placeholder-group.jpg" alt="Ryhmäkuva" class="absolute inset-0 w-full h-full object-cover" onerror="this.style.display='none'" />
        <span class="text-neutral-500 font-medium uppercase tracking-wider text-xs z-10 relative bg-white/50 backdrop-blur-sm px-4 py-2 rounded-xl">Kuva: Ryhmäkuva</span>
      </div>
    </div>
  </section>
</BaseLayout>
