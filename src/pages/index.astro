---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import homepageDataRaw from "../data/homepage.json";
import { getAsset } from "../utils/assets";
const hp = homepageDataRaw as any;

// Tuodaan dynaaminen hakuohjelma
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/kuvia/*.{jpeg,jpg,png,gif,JPG}', { eager: true });
const getImg = (path: string) => getAsset(path, images);
---

<BaseLayout 
  title="Koti" 
  description="Siltajoen Sirkuksessa kasvatetaan eri rotuisia kanoja, viiriäisiä, ankkoja ja leijonaharjaskaneja. Siilon asiantunteva palvelu tarvike- ja rehumyynti aiheissa."
>
  <!-- Hero Section: Cinematic Overlay (B) -->
  <section class="relative h-screen max-h-[900px] w-full overflow-hidden bg-black -mt-24">
    <!-- Background Image Grid -->
    <div class="absolute inset-0 grid grid-cols-1 sm:grid-cols-3 gap-1 opacity-50">
      {getImg(hp.heroImage1) ? (
        <Image
          src={getImg(hp.heroImage1)!}
          alt=""
          class="w-full h-full object-cover"
          style="object-position: 54% 36%"
          loading="eager"
          fetchpriority="high"
          width={800}
          height={900}
        />
      ) : (
        <img src={hp.heroImage1} alt="" class="w-full h-full object-cover" style="object-position: 54% 36%" fetchpriority="high" />
      )}
      {getImg(hp.heroImage3) ? (
        <Image
          src={getImg(hp.heroImage3)!}
          alt=""
          class="w-full h-full object-cover hidden sm:block"
          loading="eager"
          width={800}
          height={900}
        />
      ) : (
        <img src={hp.heroImage3} alt="" class="w-full h-full object-cover hidden sm:block" loading="eager" />
      )}
      {getImg(hp.heroImage2) ? (
        <Image
          src={getImg(hp.heroImage2)!}
          alt=""
          class="w-full h-full object-cover hidden sm:block"
          style="object-position: 50% 30%"
          loading="eager"
          width={800}
          height={900}
        />
      ) : (
        <img src={hp.heroImage2} alt="" class="w-full h-full object-cover hidden sm:block" style="object-position: 50% 30%" loading="eager" />
      )}
    </div>
    <!-- Dark Gradient Overlay -->
    <div class="absolute inset-0 z-[1]" style="background: linear-gradient(180deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 40%, rgba(0,0,0,0.8) 100%)"></div>
    <!-- Content -->
    <div class="relative z-[2] h-full flex flex-col justify-end px-8 sm:px-12 md:px-16 pb-24 sm:pb-20 max-w-[900px] reveal">
      <span class="font-headline text-[11px] font-extrabold uppercase tracking-[0.4em] text-primary mb-5">Siltajoen Sirkus · Leppävesi</span>
      <h1 class="font-headline text-[clamp(2.5rem,6vw,5rem)] font-black text-white leading-[0.92] tracking-tight mb-6">
        Siivekkäiden<br/>
        <span class="block text-white/40 italic">paratiisi.</span>
      </h1>
      <p class="text-lg text-white/55 max-w-[500px] leading-relaxed mb-10">
        {hp.introText}
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/elaimet" class="px-8 sm:px-10 py-4 sm:py-[18px] bg-primary text-white rounded-full font-bold text-[13px] uppercase tracking-[0.15em] hover:brightness-110 transition-all">
          Tutustu siivekkäisiimme
        </a>
        <a href={hp.shopUrl} target="_blank" rel="noopener noreferrer" class="px-8 sm:px-10 py-4 sm:py-[18px] bg-white/10 backdrop-blur text-white rounded-full font-bold text-[13px] uppercase tracking-[0.15em] hover:bg-white/20 transition-all">
          Verkkokauppaan
        </a>
      </div>
    </div>
    <!-- Scroll Hint -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-[3] text-white/30 text-[12px] uppercase tracking-[0.3em] text-center">
      Selaa alas
      <span class="block w-px h-10 bg-white/20 mx-auto mt-3 animate-pulse"></span>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="py-24 px-8 bg-surface">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
      <!-- Left Column: Headlines -->
      <div class="space-y-20 reveal">
        <div class="group">
          <a href="/blogi" class="hover:text-primary transition-colors">
            <h2 class="text-3xl sm:text-5xl md:text-6xl font-headline font-bold text-on-background border-b-4 border-on-background inline-block mb-2 hover:border-primary transition-colors uppercase">SIIVEKÄSTÄ ARKEA</h2>
          </a>
          <a href="/blogi" class="text-xl text-secondary font-bold italic hover:text-primary transition-colors inline-block">Tilan tarinat →</a>
        </div>
        <div class="group">
          <h2 class="text-3xl sm:text-5xl md:text-6xl font-headline font-bold text-on-background border-b-4 border-on-background inline-block mb-2 uppercase tracking-tight">SIRKUKSEN</h2>
          <a href="https://siltajoensirkus.blogspot.com/" target="_blank" rel="noopener noreferrer" class="text-xl text-secondary font-bold italic hover:text-primary transition-colors inline-block">Blogiin →</a>
        </div>
        <div class="group cursor-default">
          <h2 class="text-3xl sm:text-5xl md:text-6xl font-headline font-bold text-on-background border-b-4 border-on-background inline-block mb-2 uppercase tracking-widest">SIILON</h2>
          <a href={hp.shopUrl} target="_blank" rel="noopener noreferrer" class="text-xl text-secondary font-bold italic hover:text-primary transition-colors inline-block">Verkkokauppaan &rarr;</a>
        </div>
        <div class="pt-8 flex flex-col sm:flex-row gap-4">
          <a href={hp.shopUrl} target="_blank" rel="noopener noreferrer" class="bg-zinc-900 text-white text-center px-10 py-4 font-bold tracking-widest uppercase text-sm hover:bg-zinc-700 transition-colors inline-block">
              OSTOKSILLE VERKKOKAUPPAAN
          </a>
        </div>
      </div>
      <!-- Right Column: Finnish Body Text -->
      <div class="space-y-12 text-zinc-500 text-lg leading-relaxed pt-4 reveal">
        <p>
            {hp.introText}
        </p>
        <p>
            {hp.introText2}
        </p>
        <p>
            Siilon asiantunteva palvelu tarvike- ja rehumyynti aiheissa. Verkkokaupan kautta postitukset ympäri Suomen, noutotilaukset Siltajoelta Leppävedeltä tai rehureiteiltä.
        </p>
      </div>
    </div>
  </section>

  <!-- Coming Soon Section -->
  {hp.comingSoon?.show && (
    <section class="py-24 px-8 bg-zinc-900 text-white overflow-hidden">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-16">
        <div class="w-full md:w-1/2 reveal">
          <span class="text-primary font-bold uppercase tracking-[0.2em] text-xs mb-4 block">{hp.comingSoon.title}</span>
          <h2 class="text-5xl md:text-7xl font-headline font-black italic mb-8 uppercase leading-none tracking-tighter">{hp.comingSoon.text}</h2>
          <div class="flex items-center gap-4 mb-10">
            <span class="material-symbols-outlined text-primary text-4xl">calendar_month</span>
            <span class="text-2xl font-bold italic">{hp.comingSoon.date}</span>
          </div>
          <a href="/yhteystiedot" class="inline-block px-10 py-4 border-2 border-white rounded-full font-bold uppercase text-sm hover:bg-white hover:text-black transition-all">Varaa ennakkoon</a>
        </div>
        <div class="w-full md:w-1/2 reveal">
          <div class="aspect-[4/5] rounded-[3rem] overflow-hidden border-8 border-zinc-800 rotate-2 shadow-2xl relative">
             {getImg(hp.comingSoon.image) ? (
               <Image 
                 src={getImg(hp.comingSoon.image)!} 
                 alt="Tulossa pian - Siltajoen Sirkus" 
                 class="absolute inset-0 w-full h-full object-cover" 
                 width={800}
                 height={1000}
               />
             ) : (
               <img src={hp.comingSoon.image} alt="Coming soon" class="absolute inset-0 w-full h-full object-cover" />
             )}
             <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Animal Imagery Grid -->
  <section class="py-24 px-8 bg-surface">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="aspect-square bg-zinc-100 flex items-center justify-center rounded-2xl overflow-hidden shadow-xl border border-outline/5 transition-transform hover:scale-[1.02] reveal">
          {getImg(hp.heroImage1) ? (
            <Image src={getImg(hp.heroImage1)!} alt="Siltajoen Sirkus 1" class="w-full h-full object-cover" width={600} height={600} />
          ) : (
            <img src={hp.heroImage1} class="w-full h-full object-cover" />
          )}
      </div>
      <div class="aspect-square bg-zinc-100 flex items-center justify-center rounded-2xl overflow-hidden shadow-xl border border-outline/5 transition-transform hover:scale-[1.02] reveal" style="transition-delay: 200ms">
          {getImg(hp.heroImage2) ? (
            <Image src={getImg(hp.heroImage2)!} alt="Siltajoen Sirkus 2" class="w-full h-full object-cover" width={600} height={600} />
          ) : (
            <img src={hp.heroImage2} class="w-full h-full object-cover" />
          )}
      </div>
      <div class="aspect-square bg-zinc-100 flex items-center justify-center rounded-2xl overflow-hidden shadow-xl border border-outline/5 transition-transform hover:scale-[1.02] reveal" style="transition-delay: 400ms">
          {getImg(hp.heroImage3) ? (
            <Image src={getImg(hp.heroImage3)!} alt="Siltajoen Sirkus 3" class="w-full h-full object-cover" width={600} height={600} />
          ) : (
            <img src={hp.heroImage3} class="w-full h-full object-cover" />
          )}
      </div>
    </div>
  </section>

  <!-- Social Media Banners -->
  <section class="py-16 px-8 bg-surface-variant/50 border-t border-outline/5">
    <div class="max-w-5xl mx-auto flex flex-col items-center">
      <h2 class="text-3xl md:text-5xl font-headline font-black mb-12 italic tracking-tight text-center text-primary reveal">Seuraa meitä somessa</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full">
        <!-- Instagram Banner -->
        <a href={hp.instagramUrl} target="_blank" rel="noopener noreferrer" class="block overflow-hidden rounded-[2rem] hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 border-4 border-white group relative bg-white reveal">
          <img src="https://ee375749e6.clvaw-cdnwnd.com/7e950b1ba3cfb0d7a29604269e8df2ec/200000066-ef1c3ef1c7/700/Kurkkaa%20instassa.webp?ph=ee375749e6" alt="Kurkkaa instassa" class="w-full h-auto object-cover opacity-90 group-hover:opacity-100 transition-opacity" loading="lazy" />
          <div class="absolute inset-0 ring-1 ring-inset ring-black/10 rounded-[2rem]"></div>
        </a>
        <!-- Facebook Banner -->
        <a href={hp.facebookUrl} target="_blank" rel="noopener noreferrer" class="block overflow-hidden rounded-[2rem] hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 border-4 border-white group relative bg-white reveal" style="transition-delay: 200ms">
          <img src="https://ee375749e6.clvaw-cdnwnd.com/7e950b1ba3cfb0d7a29604269e8df2ec/200000067-813a6813a9/700/Untitled%20design.webp?ph=ee375749e6" alt="Siltajoen Sirkus Facebookissa" class="w-full h-auto object-cover opacity-90 group-hover:opacity-100 transition-opacity" loading="lazy" />
          <div class="absolute inset-0 ring-1 ring-inset ring-black/10 rounded-[2rem]"></div>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
